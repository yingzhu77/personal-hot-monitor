# ACG Pulse - Production Environment Configuration
# Copy this file to .env and fill in the values

# AI Provider (required for sentiment analysis)
# Options: openrouter | deepseek | mimo
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepSeek (alternative)
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Xiaomi MiMo Token Plan (alternative)
# AI_PROVIDER=mimo
# MIMO_API_KEY=tp-xxxxx
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# Admin (required - CHANGE THESE!)
ADMIN_PASSWORD=your_secure_password_here
ADMIN_JWT_SECRET=your_random_secret_here_at_least_32_chars

# Bilibili Configuration
# Direct API fallback: use Bilibili API when RSSHub is unavailable
BILIBILI_DIRECT_API_FALLBACK=true
# Generic cookie for direct API (copy from any BILIBILI_COOKIE_XXX)
BILIBILI_COOKIE=your_bilibili_cookie_here

# Per-UID Bilibili Cookies (for RSSHub routes)
# BILIBILI_COOKIE_401742377=SESSDATA=xxx; bili_jct=xxx; DedeUserID=xxx
# BILIBILI_COOKIE_1340190821=SESSDATA=xxx; bili_jct=xxx; DedeUserID=xxx

# Feed limit (max items to keep in database)
MAX_FEED_ITEMS=2000

# Health log retention (days, default: 30)
HEALTH_LOG_RETENTION_DAYS=30

# Report timezone (default: Asia/Shanghai)
REPORT_TIMEZONE=Asia/Shanghai
