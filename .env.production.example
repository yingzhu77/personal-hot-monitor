# Game Pulse - Production Environment Configuration
# Copy this file to .env and fill in the values

# AI Provider (required)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Or use DeepSeek:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Or use Xiaomi MiMo Token Plan:
# AI_PROVIDER=mimo
# MIMO_API_KEY=tp-xxxxx
# MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Admin (required - CHANGE THESE!)
ADMIN_PASSWORD=your_secure_password_here
ADMIN_JWT_SECRET=your_random_secret_here_at_least_32_chars

# Bilibili Cookies (optional - for better Bilibili support)
# BILIBILI_COOKIE_401742377=your_cookie_here
# BILIBILI_COOKIE_1340190821=your_cookie_here
