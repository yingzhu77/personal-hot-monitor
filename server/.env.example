# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Admin Auth
ADMIN_PASSWORD=change_me
ADMIN_JWT_SECRET=change_me_to_a_long_random_secret

# AI Provider (openrouter or deepseek)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v3.2
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# RSSHub (optional, defaults to https://rsshub.app)
RSSHUB_BASE_URL=https://rsshub.app
# Comma/semicolon/space separated fallback instances. Put self-hosted RSSHub first when available.
RSSHUB_BASE_URLS=http://127.0.0.1:1200,https://rsshub.app
RSS_FETCH_TIMEOUT_MS=30000
SOURCE_CHECK_TIMEOUT_MS=45000
SOURCE_CHECK_CONCURRENCY=3

# Bilibili
# RSSHub routes are tried first. Direct API fallback is disabled by default to avoid anti-crawl checks.
BILIBILI_DIRECT_API_FALLBACK=false
BILIBILI_DIRECT_API_TIMEOUT_MS=30000
BILIBILI_REQUEST_INTERVAL_MS=6000
# Optional login cookie for direct API fallback. Do not commit a real value.
BILIBILI_COOKIE=

# RSSHub Bilibili cookies for self-hosted RSSHub. Put these in the project-root .env used by docker compose,
# not in frontend code or committed files.
BILIBILI_DM_IMG_LIST=
BILIBILI_COOKIE_401742377=
BILIBILI_COOKIE_1340190821=
BILIBILI_COOKIE_27534330=
BILIBILI_COOKIE_1636034895=
BILIBILI_COOKIE_1955897084=
BILIBILI_COOKIE_161775300=
BILIBILI_COOKIE_1265652806=

# Email notifications (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
NOTIFY_EMAIL=notify_to@example.com

# Feed item limit (default: 2000, older items will be automatically deleted)
MAX_FEED_ITEMS=2000
