// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Notification {
  id         String    @id @default(uuid())
  type       String    // feed_item, alert, digest
  title      String
  content    String
  isRead     Boolean   @default(false)
  feedItemId String?
  channel    String    @default("in_app")
  status     String    @default("created")
  createdAt  DateTime  @default(now())
  feedItem   FeedItem? @relation(fields: [feedItemId], references: [id], onDelete: SetNull)
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Source {
  id            String     @id @default(uuid())
  name          String
  type          String     // rss, rsshub, bilibili_video, official_site, trend
  game          String
  url           String?
  uid           String?
  avatar        String?    // B站用户头像 URL
  route         String?
  config        String?
  isOfficial    Boolean    @default(false)
  followed      Boolean    @default(false)
  enabled       Boolean    @default(true)
  priority      Int        @default(50)
  healthStatus  String     @default("unknown") // unknown, healthy, failed
  lastSuccessAt DateTime?
  lastCheckedAt DateTime?
  lastError     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  feedItems     FeedItem[]

  @@index([enabled, type])
  @@index([game])
}

model FeedItem {
  id          String         @id @default(uuid())
  sourceId    String
  externalId  String?
  itemKind    String         @default("official_post") // official_post, creator_video, trend, forum_thread
  game        String
  title       String
  content     String
  url         String
  authorName  String?
  authorUrl   String?
  coverUrl    String?
  sourceType  String
  contentHash String
  hidden      Boolean        @default(false)
  publishedAt DateTime?
  fetchedAt   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  source      Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  analysis    Analysis?
  notifications Notification[]

  @@unique([sourceId, contentHash])
  @@index([game, hidden, publishedAt])
  @@index([itemKind])
}

model Analysis {
  id          String   @id @default(uuid())
  feedItemId  String   @unique
  status      String   @default("pending") // pending, completed, failed
  category    String?
  importance  String   @default("low") // low, medium, high; legacy urgent is mapped to high at the API boundary
  visibility  String   @default("public") // public, muted, hidden
  confidence  Int      @default(50)
  summary     String?
  reason      String?
  dedupKeywords String?
  provider    String?
  model       String?
  error       String?
  analyzedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  feedItem    FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([importance])
  @@index([visibility])
  @@index([category])
}

model CommunityTopic {
  id             String   @id // e.g. "bilibili-12345", "nga-67890"
  title          String
  sentiment      String   // positive, negative, neutral
  sentimentScore Float    @default(0)
  heatScore      Float    @default(0)
  category       String
  source         String   // bilibili, nga, xiaoheihe
  trend          String   @default("[]") // JSON array of numbers
  summary        String   @default("")
  url            String
  publishedAt    DateTime
  fetchedAt      DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  @@index([source])
  @@index([sentiment])
  @@index([heatScore])
  @@index([lastSeenAt])
}
